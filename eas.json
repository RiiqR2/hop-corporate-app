{
  "cli": {
    "version": ">= 16.13.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_SKIP_INSTALL_DEPS": "1",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    },
    "internal-android-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_SKIP_INSTALL_DEPS": "1",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    },
    "ios-adhoc": {
      "developmentClient": false,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}

